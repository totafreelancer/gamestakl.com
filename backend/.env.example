# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-generate-a-new-one-for-production
DEBUG=False
ALLOWED_HOSTS=.onrender.com,your-app.onrender.com

# Database (Render will set DATABASE_URL automatically for managed Postgres)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Frontend URL (your Vercel deployment URL)
FRONTEND_URL=https://your-frontend.vercel.app

# CORS Allowed Origins (comma-separated, no spaces)
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-frontend-git-main.vercel.app

# Redis (optional, for Channels WebSocket support on Render)
REDIS_URL=redis://your-redis-host:6379

# Payment Gateways
SHURJOPAY_API_KEY=
SHURJOPAY_STORE_ID=
SSLCOMMERZ_API_KEY=
SSLCOMMERZ_STORE_ID=
