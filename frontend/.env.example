# ===========================================
# HubZone Frontend — Environment Variables
# ===========================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For Vercel deployment, set these in:
#   Vercel Dashboard → Project → Settings → Environment Variables
# ===========================================

# Backend API URL (your Render deployment)
# Local development:    http://localhost:8000/api
# Production (Render):  https://your-app-name.onrender.com/api
VITE_API_URL=http://localhost:8000/api

# Firebase Configuration (if not already hardcoded)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
